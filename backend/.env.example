# ── VedaForge Backend Environment ──────────────────
# Copy this to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@YOUR_CLUSTER.mongodb.net
MONGODB_DB=vedaforge

# Groq AI (free, no credit card: https://console.groq.com)
GROQ_API_KEY=gsk_YOUR_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Redis (hardcoded in redis.ts, override here if needed)
# REDIS_URL=redis://...
